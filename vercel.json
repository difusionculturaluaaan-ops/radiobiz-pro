{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/dashboard/:path*",
      "destination": "/dashboard/:path*.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/player/:clientId",
      "destination": "/player/[clientId].html"
    }
  ]
}
